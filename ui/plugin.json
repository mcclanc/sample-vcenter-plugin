{
  "manifestVersion": "1.0.0",
  "requirements": {
    "plugin.api.version": "1.0.0"
  },
  "configuration": {
    "nameKey": "plugin.name",
    "icon": {
      "name": "main"
    }
  },
  "definitions": {
    "iconSpriteSheet": {
      "uri": "images/sprites.png",
      "definitions": {
        "main": {
          "x": 0,
          "y": 96
        }
      }
    },
    "i18n": {
      "locales": ["en-US"],
      "definitions": {
        "plugin.name": {
          "en-US": "App Platform as a Service"
        },
        "plugin.summary": {
          "en-US": "VMware Tanzu Platform is an AI-ready, integrated private cloud Platform-as-a-Service (PaaS) designed to accelerate development, deployment, and management of secure applications."
        }
      }
    }
  },
  "global": {
    "view": {
      "navigationId": "tanzuHubPoc",
      "uri": "index.html",
      "navigationVisible": true
    }
  }
}
