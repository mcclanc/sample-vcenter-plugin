{
  "name": "sample-vcenter-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Remote vSphere Client plug-in scaffold for Tanzu Hub / evaluation POC appliance workflows",
  "type": "module",
  "scripts": {
    "start": "node server/index.mjs",
    "start:https": "SSL_KEY_PATH=certs/dev-key.pem SSL_CERT_PATH=certs/dev-cert.pem node server/index.mjs",
    "dev": "node --watch server/index.mjs",
    "certs": "bash scripts/gen-dev-certs.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.0"
  }
}
