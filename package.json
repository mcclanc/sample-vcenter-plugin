{
  "name": "sample-vcenter-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Remote vSphere Client plug-in (App Platform as a Service) for Tanzu Hub / evaluation POC appliance workflows",
  "type": "module",
  "scripts": {
    "start": "node server/index.mjs",
    "start:https": "node scripts/start-https.mjs",
    "dev": "node --watch server/index.mjs",
    "tools:ovftool-mac": "bash tools/download-ovftool-mac.sh",
    "certs": "node scripts/gen-dev-certs.mjs",
    "register:lab": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-extension-lab.ps1",
    "icon:sprite": "python3 scripts/gen_plugin_icon_sprite.py",
    "icon:compose": "python3 scripts/compose_icon_into_sprite.py"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^2.1.1"
  }
}
