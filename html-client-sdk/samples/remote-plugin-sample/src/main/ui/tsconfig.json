{
   "compileOnSave": false,
   "compilerOptions": {
    "downlevelIteration": true,
    "module": "esnext",
      "outDir": "./dist/out-tsc",
      "sourceMap": true,
      "declaration": false,
      "moduleResolution": "node",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "target": "ES2022",
      "typeRoots": [
         "node_modules/@types"
      ],
      "lib": [
         "ES2022",
         "DOM"
      ],
      "baseUrl": "./src",
      "paths": {
         "~services/*": [
            "app/services/*"
         ],
         "~models/*": [
            "app/model/*"
         ]
      },
      "strict": true,
   }
}
